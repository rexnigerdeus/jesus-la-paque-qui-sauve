{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "Attendee registration for the Easter event.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the attendee."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Phone number of the attendee."
        },
        "residence": {
          "type": "string",
          "description": "Place of residence of the attendee."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the registration was created."
        }
      },
      "required": ["fullName", "phoneNumber", "residence", "createdAt"]
    }
  },
  "firestore": {
    "registrations": {
      "schema": "Registration",
      "description": "Collection of event registrations."
    }
  }
}
